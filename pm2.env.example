# Copy to .env.local on the server (or set PM2_ENV_FILE to another path).
# Same variables as app/config.py (pydantic-settings). Do not commit real secrets.

# --- Database (same Postgres as DMRC_HRMS_API) ---
# Option A: full URL (passwords with @ must work; config normalizes @ in password)
# CHATBOT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: discrete fields
POSTGRES_HOST=localhost
POSTGRES_LOCAL_PORT=5432
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres

# --- Redis ---
# If Redis uses requirepass, either set password here or embed in REDIS_URL:
#   REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379
# REDIS_USERNAME=default
# REDIS_PASSWORD=

# --- HRMS API ---
HRMS_BASE_URL=http://localhost:3001/api
HRMS_TIMEOUT=15

# --- JWT (GET /v1/chat/history uses HS256 + JWT_SECRET; falls back to SECRET_KEY if empty) ---
# JWT_SECRET=

# --- LLM ---
# groq | vllm | deepinfra
LLM_PROVIDER=groq
GROQ_API_KEY=

# DeepInfra (OpenAI-compatible) — https://api.deepinfra.com/v1/openai
# LLM_PROVIDER=deepinfra
# DEEPINFRA_TOKEN=           # or DEEPINFRA_API_KEY
# DEEPINFRA_MODEL=deepseek-ai/DeepSeek-V3
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
# Optional: faster model for final response polish only (same DEEPINFRA token). If unset, uses DEEPINFRA_MODEL.
# Invalid ids fall back to DEEPINFRA_MODEL automatically. Use a name that exists on your DeepInfra dashboard.
# LLM_REVIEW_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# Optional: set false to skip reviewer LLM pass and reduce latency.
# ENABLE_RESPONSE_REVIEW=true

# --- JWT / SSO ---
SSO_PUBLIC_KEY=
SECRET_KEY=

# --- App ---
DEBUG=false

# Optional: listen port (ecosystem.config.js reads PORT for uvicorn --port)
# PORT=8001
